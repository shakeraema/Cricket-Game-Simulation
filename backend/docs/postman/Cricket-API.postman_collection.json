        {
          "name": "Create Match",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\\n  \"teamA\": \"India\",\\n  \"teamB\": \"Australia\",\\n  \"overs\": 5\\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/match/create",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "match",
                "create"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Create match success envelope', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.success).to.eql(true);",
                  "  pm.expect(body.data).to.have.property('matchId');",
                  "});",
                  "",
                  "pm.test('Save matchId for chained requests', function () {",
                  "  const body = pm.response.json();",
                  "  if (body && body.data && body.data.matchId) {",
                  "    pm.environment.set('matchId', body.data.matchId);",
                  "  }",
                  "});"
                ]
              }
            }
          ]
        },
