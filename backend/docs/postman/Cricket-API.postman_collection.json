{
  "info": {
    "_postman_id": "7a2c59d8-b2d2-4f71-a9f1-4ac26277b2a2",
    "name": "Cricket Simulation API",
    "description": "API-first contract collection for Cricket Match Simulation.\\n\\nAuth modes:\\n- Public endpoints: no auth\\n- Protected endpoints: Bearer token (set {{bearerToken}})\\n\\nAll endpoints return standardized JSON envelopes:\\n- success: { success, message, data }\\n- error: { success, message, error }",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Public",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\\n  \"name\": \"Jane Doe\",\\n  \"email\": \"jane@example.com\",\\n  \"password\": \"secret123\"\\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "register"
              ]
            },
            "description": "Create a credentials user account"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Response uses standard envelope', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.property('success');",
                  "  pm.expect(body).to.have.property('message');",
                  "  pm.expect(body).to.have.property('data');",
                  "  pm.expect(body.success).to.eql(true);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Login User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\\n  \"email\": \"jane@example.com\",\\n  \"password\": \"secret123\"\\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            },
            "description": "Credentials login for API clients; stores bearerToken variable"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response includes bearer token', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.success).to.eql(true);",
                  "  pm.expect(body.data).to.have.property('token');",
                  "  pm.expect(body.data.tokenType).to.eql('Bearer');",
                  "  pm.environment.set('bearerToken', body.data.token);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Teams",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/teams",
              "host": [
