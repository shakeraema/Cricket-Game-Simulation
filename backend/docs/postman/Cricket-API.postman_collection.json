                  "});",
                  "",
                  "pm.test('Response data is an array', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.success).to.eql(true);",
                  "  pm.expect(body.data).to.be.an('array');",
                  "});"
                ]
              }
            }
          ]
        },
